{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Release (Ninja)",
      "description": "Configure with Ninja generator in Release mode",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Ninja)",
      "description": "Configure with Ninja generator in Debug mode",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-release",
      "displayName": "Build Release",
      "configurePreset": "release"
    },
    {
      "name": "build-debug",
      "displayName": "Build Debug",
      "configurePreset": "debug"
    }
  ]
}
